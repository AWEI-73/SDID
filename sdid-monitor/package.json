{
  "name": "sdid-monitor",
  "version": "1.1.0",
  "description": "SDID Monitor — 流程架構監控與專案進程追蹤",
  "main": "main.cjs",
  "scripts": {
    "start":           "node server.cjs",
    "start:electron":  "electron .",
    "dist":            "electron-builder -w --x64 --dir",
    "dist:packager":   "npx electron-packager . \"SDID Monitor\" --platform=win32 --arch=x64 --out=dist_packager --overwrite --ignore=dist_packager --ignore=dist --ignore=README.md"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^4.18.2"
  },
  "build": {
    "appId":       "com.sdid.monitor",
    "productName": "SDID Monitor",
    "copyright":   "SDID Project",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "server.cjs",
      "update-hub.cjs",
      "index.html",
      "hub.json",
      "milestones.json",
      "tray-icon.png",
      "node_modules/**"
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "forceCodeSigning": false
    }
  },
  "devDependencies": {
    "electron":         "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
