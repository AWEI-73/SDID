{
    "version": "1.0.0",
    "description": "Phase Registry - 單一真相來源，定義所有階段及其元資訊",
    "BUILD": {
        "phases": [
            "1",
            "2",
            "3",
            "4"
        ],
        "prefix": "phase",
        "schemaVersion": "v6",
        "definitions": {
            "1": {
                "name": "骨架映射層",
                "file": "phase-1.cjs",
                "description": "讀取 implementation plan + contract.ts，產出骨架 + GEMS 標籤全覆蓋（P0-P3）",
                "actions": [
                    "Read implementation plan",
                    "Read contract.ts for type alignment",
                    "Generate skeleton with GEMS tags (all functions, P0-P3)",
                    "Write checkpoint"
                ],
                "requires": [
                    "implementation_plan",
                    "contract_ts"
                ],
                "produces": [
                    "source_code"
                ]
            },
            "2": {
                "name": "TDD 驗收層",
                "file": "phase-2.cjs",
                "description": "執行 contract.ts 的 @TEST 路徑（vitest --run），或 tsc --noEmit（無測試路徑）",
                "actions": [
                    "Locate contract.ts",
                    "Extract @TEST paths (v4 schema only)",
                    "Run vitest --run on test paths, or tsc --noEmit if no @TEST",
                    "PASS only when all tests GREEN"
                ],
                "requires": [
                    "source_code",
                    "contract_ts"
                ],
                "produces": [
                    "test_results"
                ]
            },
            "3": {
                "name": "整合層",
                "file": "phase-3.cjs",
                "description": "跨模組整合檢查：路由、模組匯出",
                "actions": [
                    "Check route integration",
                    "Verify module exports (index.ts facade)",
                    "Check dependency direction"
                ],
                "requires": [],
                "produces": [],
                "skipInLevels": [
                    "S"
                ]
            },
            "4": {
                "name": "Trace Closure + Entrypoint Metadata",
                "file": "phase-4.cjs",
                "description": "Contract→Plan→Source→GEMS tag 鏈條驗證 + GEMS tag 格式（JSDoc 單行）+ skeleton residue 偵測 + entrypoint metadata check（light，不執行 build/typecheck，不宣稱 SCAN）",
                "actions": [
                    "Validate Contract→Plan→Source→GEMS tag trace chain per story",
                    "Check GEMS tag JSDoc single-line format (no multiline)",
                    "Detect skeleton residue (throw new Error / TODO placeholder)",
                    "Entrypoint metadata check (package.json / appsscript.json / index.html)"
                ],
                "requires": [
                    "implementation_plan",
                    "source_code"
                ],
                "produces": [
                    "phase4_done_marker"
                ],
                "checkFile": "build/phase4-done_{story}",
                "_note": "phase4-done_Story-X.Y 是 Build story completion marker。functions.json / project overview 由 SCAN 階段產出，不屬於 Phase 4。"
            }
        }
    },
    "SCAN": {
        "steps": [
            "scan"
        ],
        "prefix": "",
        "definitions": {
            "scan": {
                "name": "Full Scan",
                "file": "scan.cjs",
                "description": "完整專案掃描：掃描 GEMS tag 產出 function cache 與 human/agent docs。在所有 story Build Phase 4 完成後執行，VERIFY 依賴其 canonical product。",
                "actions": [
                    "Scan all GEMS tags → functions.json (canonical)",
                    "Generate project-overview.json (stats + tech-stack + stories)",
                    "Generate DB_SCHEMA.md (schema markdown)",
                    "Generate CONTRACT.md (contract summary markdown, try/catch)",
                    "Write functions-snapshot.json to iteration dir (diagnostic)",
                    "Delete deprecated files: system-blueprint.json, schema.json, tech-stack.json, function-index.json"
                ],
                "requires": [
                    "phase4_done_marker"
                ],
                "produces": {
                    "canonical": [
                        "functions_json"
                    ],
                    "auxiliary_docs": [
                        "project_overview",
                        "db_schema_md",
                        "contract_md"
                    ],
                    "iteration_diagnostic": [
                        "functions_snapshot"
                    ]
                },
                "_not_produced": [
                    "system_blueprint",
                    "function_index",
                    "schema_json",
                    "tech_stack",
                    "contract_json"
                ]
            }
        }
    },
    "VERIFY": {
        "steps": [
            "verify"
        ],
        "prefix": "",
        "definitions": {
            "verify": {
                "name": "Blueprint Verify",
                "file": "sdid-tools/blueprint/verify.cjs",
                "description": "Blueprint ↔ Source 雙向語意比對，使用 SCAN canonical product（functions.json）。不做 auto-scan，不接受隱式 fallback。VERIFY pass 後輸出 BLUEPRINT_FILLBACK_PENDING hook。",
                "requires": [
                    "functions_json"
                ],
                "_not_accepted": [
                    "function_index",
                    "functions_snapshot",
                    "auto_scan"
                ],
                "produces": [
                    "blueprint_verify_report",
                    "blueprint_fillback_pending"
                ]
            }
        }
    },
    "levelPhases": {
        "_deprecated": "S/M/L level 已廢棄，BUILD 固定跑 Phase 1-4，Phase 3 由 story type 決定是否跳過（Foundation X.0 自動跳過）",
        "S": ["1", "2", "3", "4"],
        "M": ["1", "2", "3", "4"],
        "L": ["1", "2", "3", "4"],
        "default": ["1", "2", "3", "4"]
    },
    "flowSequence": [
        { "phase": "BUILD",  "step": "1" },
        { "phase": "BUILD",  "step": "2" },
        { "phase": "BUILD",  "step": "3" },
        { "phase": "BUILD",  "step": "4" },
        { "phase": "SCAN",   "step": "scan" },
        { "phase": "VERIFY", "step": "verify" }
    ],
    "_flowNote": "Build Phase 4 寫 phase4-done_Story-X.Y（每 story）。所有 story 完成後進 SCAN，SCAN pass 後進 VERIFY，VERIFY pass 後 BLUEPRINT_FILLBACK_PENDING（fillback 工具尚待實作）。Fillback_Story-X.Y.md 是 VERIFY 後產物，不再作為 Build story completion marker。"
}