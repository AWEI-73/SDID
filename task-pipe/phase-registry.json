{
    "version": "1.0.0",
    "description": "Phase Registry - 單一真相來源，定義所有階段及其元資訊",
    "POC": {
        "steps": [
            "1",
            "2",
            "3",
            "4",
            "5"
        ],
        "prefix": "step",
        "definitions": {
            "1": {
                "name": "Draft Generation",
                "file": "step-1.cjs",
                "description": "產生需求草稿",
                "actions": [
                    "Check requirement ambiguity",
                    "Mark [NEEDS CLARIFICATION]"
                ],
                "requires": [],
                "produces": [
                    "requirement_draft"
                ],
                "checkFile": "poc/requirement_draft_{iteration}.md"
            },
            "2": {
                "name": "Environment Check",
                "file": "step-2.cjs",
                "description": "環境檢查",
                "actions": [
                    "Verify project structure"
                ],
                "requires": [
                    "requirement_draft"
                ],
                "produces": []
            },
            "3": {
                "name": "Contract & POC",
                "file": "step-3.cjs",
                "description": "建立資料契約與 POC",
                "actions": [
                    "Design data contract",
                    "Generate @GEMS-CONTRACT"
                ],
                "requires": [],
                "produces": [
                    "contract"
                ],
                "checkFile": "poc/*Contract.ts"
            },
            "4": {
                "name": "POC Quality",
                "file": "step-4.cjs",
                "description": "POC 品質檢查",
                "actions": [
                    "Create UI prototype",
                    "Generate POC.html"
                ],
                "requires": [
                    "contract"
                ],
                "produces": [
                    "poc_html"
                ],
                "checkFile": "poc/*POC.html"
            },
            "5": {
                "name": "Spec Generation",
                "file": "step-5.cjs",
                "description": "產生需求規格",
                "actions": [
                    "Generate requirement spec",
                    "Verify independent testability"
                ],
                "requires": [
                    "poc_html"
                ],
                "produces": [
                    "requirement_spec"
                ],
                "checkFile": "poc/requirement_spec_{iteration}.md"
            }
        }
    },
    "BUILD": {
        "phases": [
            "1",
            "2",
            "3",
            "4"
        ],
        "prefix": "phase",
        "schemaVersion": "v6",
        "definitions": {
            "1": {
                "name": "骨架映射層",
                "file": "phase-1.cjs",
                "description": "讀取 implementation plan + contract.ts + ac.ts，產出骨架 + GEMS 標籤全覆蓋（P0-P3）",
                "actions": [
                    "Read implementation plan",
                    "Read contract.ts for type alignment",
                    "Read ac.ts for AC ID mapping",
                    "Generate skeleton with GEMS tags (all functions, P0-P3)",
                    "Write checkpoint"
                ],
                "requires": [
                    "implementation_plan",
                    "contract_ts"
                ],
                "produces": [
                    "source_code"
                ]
            },
            "2": {
                "name": "AC 驗收層",
                "file": "phase-2.cjs",
                "description": "呼叫 ac-runner 執行 ac.ts（或 contract.ts）的 @GEMS-AC，CALC AC 全 PASS 才過",
                "actions": [
                    "Locate ac.ts or contract.ts",
                    "Run ac-runner",
                    "Relay ac-runner @TASK output on failure",
                    "PASS only when all CALC AC pass (SKIP[CANVAS/INTEGRATION/EXTERNAL] excluded)"
                ],
                "requires": [
                    "source_code",
                    "ac_spec"
                ],
                "produces": [
                    "ac_results"
                ]
            },
            "3": {
                "name": "整合層",
                "file": "phase-3.cjs",
                "description": "跨模組整合檢查：路由、模組匯出、SKIP[INTEGRATION] AC",
                "actions": [
                    "Check route integration",
                    "Verify module exports (index.ts facade)",
                    "Run SKIP[INTEGRATION] AC via ac-runner if applicable",
                    "Check dependency direction"
                ],
                "requires": [
                    "ac_results"
                ],
                "produces": [],
                "skipInLevels": [
                    "S"
                ]
            },
            "4": {
                "name": "標籤品質+Fillback層",
                "file": "phase-4.cjs",
                "description": "GEMS 標籤品質複查（全覆蓋驗收）+ 產出 Fillback 與 Suggestions",
                "actions": [
                    "Scan GEMS tags quality (all P0-P3, GEMS-FLOW completeness, AC ID alignment)",
                    "Scan source to generate Fillback",
                    "Generate Suggestions JSON",
                    "Update functions.json"
                ],
                "requires": [],
                "produces": [
                    "fillback",
                    "suggestions"
                ],
                "checkFile": "build/Fillback_{story}.md"
            }
        }
    },
    "SCAN": {
        "steps": [
            "scan"
        ],
        "prefix": "",
        "definitions": {
            "scan": {
                "name": "Full Scan",
                "file": "scan.cjs",
                "description": "完整專案掃描",
                "actions": [
                    "Scan all GEMS tags",
                    "Generate functions.json",
                    "Generate system-blueprint.json"
                ],
                "requires": [],
                "produces": [
                    "functions_json",
                    "system_blueprint"
                ]
            }
        }
    },
    "levelPhases": {
        "_deprecated": "S/M/L level 已廢棄，BUILD 固定跑 Phase 1-4，Phase 3 由 story type 決定是否跳過（Foundation X.0 自動跳過）",
        "S": ["1", "2", "3", "4"],
        "M": ["1", "2", "3", "4"],
        "L": ["1", "2", "3", "4"],
        "default": ["1", "2", "3", "4"]
    },
    "flowSequence": [
        {
            "phase": "POC",
            "step": "1"
        },
        {
            "phase": "POC",
            "step": "2"
        },
        {
            "phase": "POC",
            "step": "3"
        },
        {
            "phase": "POC",
            "step": "4"
        },
        {
            "phase": "POC",
            "step": "5"
        },
        {
            "phase": "SPEC_TO_PLAN",
            "step": "run"
        },
        {
            "phase": "BUILD",
            "step": "1"
        },
        {
            "phase": "BUILD",
            "step": "2"
        },
        {
            "phase": "BUILD",
            "step": "3"
        },
        {
            "phase": "BUILD",
            "step": "4"
        },
        {
            "phase": "SCAN",
            "step": "scan"
        }
    ]
}