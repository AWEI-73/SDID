            "step": "run"
        },
        {
            "phase": "BUILD",
            "step": "1"
        },
        {
            "phase": "BUILD",
            "step": "2"
        },
        {
            "phase": "BUILD",
            "step": "3"
        },
        {
            "phase": "BUILD",
            "step": "4"
        },
        {
            "phase": "BUILD",
            "step": "5"
        },
        {
            "phase": "BUILD",
            "step": "6"
        },
        {
            "phase": "BUILD",
            "step": "7"
        },
        {
            "phase": "BUILD",
