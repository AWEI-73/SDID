{
    "version": "1.0.0",
    "description": "Phase Registry - 單一真相來源，定義所有階段及其元資訊",
    "BUILD": {
        "phases": [
            "1",
            "2",
            "3",
            "4"
        ],
        "prefix": "phase",
        "schemaVersion": "v6",
        "definitions": {
            "1": {
                "name": "骨架映射層",
                "file": "phase-1.cjs",
                "description": "讀取 implementation plan + contract.ts，產出骨架 + GEMS 標籤全覆蓋（P0-P3）",
                "actions": [
                    "Read implementation plan",
                    "Read contract.ts for type alignment",
                    "Generate skeleton with GEMS tags (all functions, P0-P3)",
                    "Write checkpoint"
                ],
                "requires": [
                    "implementation_plan",
                    "contract_ts"
                ],
                "produces": [
                    "source_code"
                ]
            },
            "2": {
                "name": "TDD 驗收層",
                "file": "phase-2.cjs",
                "description": "執行 contract.ts 的 @TEST 路徑（vitest --run），或 tsc --noEmit（無測試路徑）",
                "actions": [
                    "Locate contract.ts",
                    "Extract @TEST paths (v4 schema only)",
                    "Run vitest --run on test paths, or tsc --noEmit if no @TEST",
                    "PASS only when all tests GREEN"
                ],
                "requires": [
                    "source_code",
                    "contract_ts"
                ],
                "produces": [
                    "test_results"
                ]
            },
            "3": {
                "name": "整合層",
                "file": "phase-3.cjs",
                "description": "跨模組整合檢查：路由、模組匯出",
                "actions": [
                    "Check route integration",
                    "Verify module exports (index.ts facade)",
                    "Check dependency direction"
                ],
                "requires": [],
                "produces": [],
                "skipInLevels": [
                    "S"
                ]
            },
            "4": {
                "name": "標籤品質+Fillback層",
                "file": "phase-4.cjs",
                "description": "GEMS 標籤品質複查（全覆蓋驗收）+ 產出 Fillback 與 Suggestions",
                "actions": [
                    "Scan GEMS tags quality (all P0-P3, GEMS-FLOW completeness, @TEST path alignment)",
                    "Scan source to generate Fillback",
                    "Generate Suggestions JSON",
                    "Update functions.json"
                ],
                "requires": [],
                "produces": [
                    "fillback",
                    "suggestions"
                ],
                "checkFile": "build/Fillback_{story}.md"
            }
        }
    },
    "SCAN": {
        "steps": [
            "scan"
        ],
        "prefix": "",
        "definitions": {
            "scan": {
                "name": "Full Scan",
                "file": "scan.cjs",
                "description": "完整專案掃描",
                "actions": [
                    "Scan all GEMS tags",
                    "Generate functions.json",
                    "Generate system-blueprint.json"
                ],
                "requires": [],
                "produces": [
                    "functions_json",
                    "system_blueprint"
                ]
            }
        }
    },
    "levelPhases": {
        "_deprecated": "S/M/L level 已廢棄，BUILD 固定跑 Phase 1-4，Phase 3 由 story type 決定是否跳過（Foundation X.0 自動跳過）",
        "S": ["1", "2", "3", "4"],
        "M": ["1", "2", "3", "4"],
        "L": ["1", "2", "3", "4"],
        "default": ["1", "2", "3", "4"]
    },
    "flowSequence": [
        {
            "phase": "BUILD",
            "step": "1"
        },
        {
            "phase": "BUILD",
            "step": "2"
        },
        {
            "phase": "BUILD",
            "step": "3"
        },
        {
            "phase": "BUILD",
            "step": "4"
        },
        {
            "phase": "SCAN",
            "step": "scan"
        }
    ]
}