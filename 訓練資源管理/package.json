{
    "name": "training-flow-monitor",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "jest"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "transform": {
            "^.+\\.[jt]sx?$": "babel-jest"
        },
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json"
        ],
        "testMatch": [
            "**/__tests__/**/*.test.ts",
            "**/__tests__/**/*.integration.test.ts",
            "**/__tests__/**/*.e2e.test.ts"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/dist/"
        ]
    },
    "devDependencies": {
        "@babel/preset-env": "*",
        "@babel/preset-typescript": "*",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "babel-jest": "*",
        "jest": "*",
        "jest-environment-jsdom": "*",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}